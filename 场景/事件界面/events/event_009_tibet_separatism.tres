value = 400.0

[resource]
script = ExtResource("5_4p5f1")
event_id = "tibet_separatism"
title = "Separatism in Tibet"
description = "Encouraged by liberals and nationalists, residents of the Tibet Autonomous Region took to mass demonstrations for independence and secession from the PRC, which gradually develop into unrest. People demand \"liberation\" from \"the occupation of 1950\" and the majority of ethnic Tibetans support them. However, some are just satisfied with the requirements of greater autonomy than we can take advantage of."
trigger_conditions = Array[ExtResource("4_llahx")]([SubResource("Resource_be6ah")])
options = Array[ExtResource("2_7lsgv")]([SubResource("Resource_2w88w"), SubResource("Resource_pe42h"), SubResource("Resource_unxpm"), SubResource("Resource_rch2o")])
