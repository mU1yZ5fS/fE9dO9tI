[sub_resource type="Resource" id="Resource_unxpm"]
script = ExtResource("2_7lsgv")
text = "Send in the PLA to restore order"
effects = Array[ExtResource("3_dtuc1")]([SubResource("Resource_v3quw"), SubResource("Resource_n6iib"), SubResource("Resource_dy1h5"), SubResource("Resource_u4mrn")])
result_text = "The loyal parts of the PLA entered Tibet and quickly restored order. But the nationalists and the opposition will not forget this."

