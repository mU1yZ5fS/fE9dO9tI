key = "manpower"
value = -20.0

[sub_resource type="Resource" id="Resource_pe42h"]
script = ExtResource("2_7lsgv")
text = "Expand autonomy"
effects = Array[ExtResource("3_dtuc1")]([SubResource("Resource_83prh"), SubResource("Resource_bvh11")])
result_text = "We have further expanded the powers of local authorities and the rights of Tibetan autonomy. It seems that the majority of the population is satisfied, but it gives the radicals more opportunities to promote separatism, and other national outskirts are thinking about greater independence."

