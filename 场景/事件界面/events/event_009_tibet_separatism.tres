[sub_resource type="Resource" id="Resource_2w88w"]
script = ExtResource("2_7lsgv")
text = "Allow independence"
effects = Array[ExtResource("3_dtuc1")]([SubResource("Resource_er6u3"), SubResource("Resource_gc4g2"), SubResource("Resource_vephg"), SubResource("Resource_u1baf")])
result_text = "Tibet Autonomous Region officially declared its independence within the borders of 1950. This will be a big blow for us and a great opportunity for the USSR and the USA."

[sub_resource type="Resource" id="Resource_83prh"]
script = ExtResource("3_dtuc1")
key = "party_support"
value = -200.0

[sub_resource type="Resource" id="Resource_bvh11"]
