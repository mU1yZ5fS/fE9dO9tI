[sub_resource type="Resource" id="Resource_rch2o"]
script = ExtResource("2_7lsgv")
text = "Organize a referendum"
disabled_text = "Need agents: 50 and money: 40"
enable_condition = SubResource("Resource_d0s5p")
effects = Array[ExtResource("3_dtuc1")]([SubResource("Resource_nxam8"), SubResource("Resource_sy1m1"), SubResource("Resource_uhfl7"), SubResource("Resource_m81cn")])
result_text = "We organized a referendum in which the majority, of course, voted to preserve the status of Tibet. Dissatisfied nationalists and other radicals took to the streets, claiming falsification, but without past support these protests no longer pose a serious threat."

[sub_resource type="Resource" id="Resource_be6ah"]
