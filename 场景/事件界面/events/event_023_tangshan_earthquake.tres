[resource]
script = ExtResource("5_8w18u")
event_id = "tangshan_earthquake"
title = "Tangshan earthquake"
description = "On July 28, a magnitude 8.2 earthquake on the Richter scale occurred in the city of Tangshan, Hebei Province, at 03:42 local time, as a result of which the city was almost completely destroyed. The destruction also took place in Tianjin and in Beijing... According to preliminary data, from 200 to 600 thousand people died."
trigger_conditions = Array[ExtResource("4_rykqa")]([SubResource("Resource_txetv")])
options = Array[ExtResource("2_0kx2q")]([SubResource("Resource_t8d4o"), SubResource("Resource_yu36w"), SubResource("Resource_byup5"), SubResource("Resource_1smbs")])
