[sub_resource type="Resource" id="Resource_1smbs"]
script = ExtResource("2_0kx2q")
text = "Let the provincial administration deal with it"
effects = Array[ExtResource("3_764ir")]([SubResource("Resource_ckk7l"), SubResource("Resource_3lg1i"), SubResource("Resource_i5q1n")])
result_text = "The center remained deaf to the problems of Hebei Province, which of course made it difficult to eliminate the consequences of the earthquake and gave rise to discontent."

[sub_resource type="Resource" id="Resource_txetv"]
