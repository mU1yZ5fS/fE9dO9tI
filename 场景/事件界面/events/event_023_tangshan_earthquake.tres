[sub_resource type="Resource" id="Resource_yu36w"]
script = ExtResource("2_0kx2q")
text = "Request foreign humanitarian assistance"
disabled_text = "Foreigners will not give us help"
enable_condition = SubResource("Resource_tmg4c")
effects = Array[ExtResource("3_764ir")]([SubResource("Resource_xdye3"), SubResource("Resource_vahif")])
result_text = "The world community and charitable organizations, assessing the scale of the disaster, agreed to provide us with assistance in the form of gratuitous loans and help of volunteers."

