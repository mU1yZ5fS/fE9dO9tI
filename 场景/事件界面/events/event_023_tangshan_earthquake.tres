[sub_resource type="Resource" id="Resource_t8d4o"]
script = ExtResource("2_0kx2q")
text = "Allocate funds from the budget for restoration (-3.0 from budget)"
effects = Array[ExtResource("3_764ir")]([SubResource("Resource_au3ro"), SubResource("Resource_f6wsn"), SubResource("Resource_kd8ir")])
result_text = "Funds from the PRC budget were immediately allocated to carry out rescue and restoration work, which made it possible to mitigate the effects of the earthquake."

