[sub_resource type="Resource" id="Resource_e2y4c"]
script = ExtResource("3_cg7xm")
type = 15
key = "election_free"

[sub_resource type="Resource" id="Resource_m5m3q"]
script = ExtResource("2_582so")
text = "Do not interfere and wait for results"
effects = Array[ExtResource("3_cg7xm")]([SubResource("Resource_e2y4c")])
result_text = "The election proceeds naturally. The results depend on people support and party dynamics."

[sub_resource type="Resource" id="Resource_7elp3"]
script = ExtResource("3_cg7xm")
key = "people_support"
value = -100.0

[sub_resource type="Resource" id="Resource_yimyg"]
script = ExtResource("3_cg7xm")
key = "party_support"
value = 50.0

[sub_resource type="Resource" id="Resource_hq2k1"]
script = ExtResource("4_xyfh0")
key = "party_support"
value = 500.0

[sub_resource type="Resource" id="Resource_up5mr"]
script = ExtResource("2_582so")
text = "Drive civil servants to the vote"
disabled_text = "The party blocks such brazen intervention"
enable_condition = SubResource("Resource_hq2k1")
effects = Array[ExtResource("3_cg7xm")]([SubResource("Resource_7elp3"), SubResource("Resource_yimyg")])
result_text = "With the promise of bonuses, payouts and threats of layoffs and downgrades, we managed to get the civil servants to come to the polls and vote for our party. But people will long remember such an open scam."

[sub_resource type="Resource" id="Resource_uaals"]
script = ExtResource("3_cg7xm")
