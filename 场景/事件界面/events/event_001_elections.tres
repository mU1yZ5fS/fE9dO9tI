[resource]
script = ExtResource("5_wcf6q")
event_id = "npc_elections"
title = "Elections, Elections, Candidates are..."
description = "It is the day of the national elections in the NPC. And since we occupy a dominant position in Chinese politics, we can intervene a little in their conduct, so that everything will remain same. Or just rely on the Chinese people's faith in us."
trigger_conditions = Array[ExtResource("4_xyfh0")]([SubResource("Resource_0nnos")])
options = Array[ExtResource("2_582so")]([SubResource("Resource_m5m3q"), SubResource("Resource_up5mr"), SubResource("Resource_7rwql")])
