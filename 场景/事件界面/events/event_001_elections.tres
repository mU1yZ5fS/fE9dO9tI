value = 150.0

[sub_resource type="Resource" id="Resource_ydy2g"]
script = ExtResource("4_xyfh0")
key = "agents"
value = 50.0

[sub_resource type="Resource" id="Resource_7rwql"]
script = ExtResource("2_582so")
text = "Falsify results"
disabled_text = "The intelligence services do not have enough strength"
enable_condition = SubResource("Resource_ydy2g")
effects = Array[ExtResource("3_cg7xm")]([SubResource("Resource_uaals"), SubResource("Resource_l8p3h")])
result_text = "The special services did a great job getting places for us. Only they are very tired."

[sub_resource type="Resource" id="Resource_0nnos"]
