[sub_resource type="Resource" id="Resource_yboyw"]
script = ExtResource("2_syebt")
text = "Call loyal officers!"
disabled_text = "Army will not support us"
enable_condition = SubResource("Resource_glapx")
effects = Array[ExtResource("3_2tba3")]([SubResource("Resource_l44dg"), SubResource("Resource_xl6h6"), SubResource("Resource_njk3m")])
result_text = "Even before the start of the congress, the officers loyal to you overwhelmed the conspirators who had arrived and, at gunpoint, took them to military jails. At the congress, in the presence of armed soldiers, you criticized them in absentia, which was supported by the delegates."

