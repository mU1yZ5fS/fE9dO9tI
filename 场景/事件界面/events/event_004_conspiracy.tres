[sub_resource type="Resource" id="Resource_3hpjc"]
script = ExtResource("2_syebt")
text = "Arrest conspirators!"
disabled_text = "Special services will not support us"
enable_condition = SubResource("Resource_5h0ko")
effects = Array[ExtResource("3_2tba3")]([SubResource("Resource_ckrrw"), SubResource("Resource_dyyab"), SubResource("Resource_r7men")])
result_text = "Even before the start of the congress, the secret service agents loyal to you, overwhelmed the conspirators who had arrived and sent them to the detention facilities. At the congress, you criticized them in absentia, which was supported by the delegates. But it's not so easy to get rid of high party members..."

