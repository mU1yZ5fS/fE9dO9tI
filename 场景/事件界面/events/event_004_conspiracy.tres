[sub_resource type="Resource" id="Resource_k88p2"]
script = ExtResource("2_syebt")
text = "Start polemic at the congress"
effects = Array[ExtResource("3_2tba3")]([SubResource("Resource_xqoht"), SubResource("Resource_e0qna")])
result_text = "Before the conspirators managed to voice their accusations, you attacked them with criticism and counter accusations. Most of those present at the congress supported you and the conspirators had to retreat."

