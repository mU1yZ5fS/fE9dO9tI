[sub_resource type="Resource" id="Resource_w1t1b"]
script = ExtResource("2_5y7hh")
text = "Remove Pol Pot in favor of the trio of Hu Nim, Hou Yuon and Khieu Samphan"
disabled_text = "We can't remove Pol Pot"
enable_condition = SubResource("Resource_kbt30")
effects = Array[ExtResource("3_mln7p")]([SubResource("Resource_u82pv")])
result_text = "Coming in contact with the Left Opposition within the Kampuchean army, we were able to organize the displacement and arrest of Pol Pot..."

