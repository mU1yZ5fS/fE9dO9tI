[sub_resource type="Resource" id="Resource_7if4f"]
script = ExtResource("2_5y7hh")
text = "Do not interfere"
result_text = "We decided not to intervene in the conflict. Pol Pot and the Khmer Rouge leadership, of course, are very unhappy with this, but it does not seem that they will live long..."

