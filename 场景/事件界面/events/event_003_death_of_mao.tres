[sub_resource type="Resource" id="Resource_wxm0n"]
script = ExtResource("2_1gqfx")
text = "Build Mausoleum on Tiananmen Square for Mao"
effects = Array[ExtResource("3_52bq6")]([SubResource("Resource_133yy"), SubResource("Resource_6kyrm"), SubResource("Resource_0g2jo"), SubResource("Resource_mt7vn"), SubResource("Resource_8bkh3"), SubResource("Resource_e50tb")])
result_text = "After Mao's death was announced, his body was placed in the House of People's Congregations for a week... After the deadline, Mao's body was taken to the hospital and embalmed by a specially developed technique. After three minutes of silence and Hua Guofeng's farewell speech on Tiananmen Square, the chairman rested in a mausoleum built on the same square by a special order of Guofeng."

