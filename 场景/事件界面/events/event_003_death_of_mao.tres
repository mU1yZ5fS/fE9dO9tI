[resource]
script = ExtResource("4_tx5po")
event_id = "death_of_mao"
title = "Death of helmsman"
description = "A terrible thing happened. After 2 transferred heart attacks on September 9 at 0 h. 10 min. On the 83rd year of life, the great leader and teacher of the Chinese people, Chairman Mao Zedong, passed away. As long as all the people and the party are grieving, we need to convene the funeral commission and decide how we are conduct the chairman in his last journey."
trigger_conditions = Array[ExtResource("5_7hdi0")]([SubResource("Resource_ofead")])
options = Array[ExtResource("2_1gqfx")]([SubResource("Resource_qmp3d"), SubResource("Resource_wxm0n"), SubResource("Resource_hxcig")])
