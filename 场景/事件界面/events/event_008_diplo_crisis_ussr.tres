[sub_resource type="Resource" id="Resource_172ff"]
script = ExtResource("2_8yby2")
text = "Pass a part of foreign policy positions as a sign of goodwill"
effects = Array[ExtResource("3_tql7y")]([SubResource("Resource_0t54k"), SubResource("Resource_etwxd"), SubResource("Resource_mja2a")])
result_text = "We have abandoned some foreign policy claims, reduced the support of loyal opposition in other countries and, in general, reduced the degree of interventionism of Chinese politics. This was positively perceived by the Ministry of Foreign Affairs of the USSR, tensions decreased. Like our influence."

[sub_resource type="Resource" id="Resource_45ccd"]
script = ExtResource("2_8yby2")
text = "Don't care at all"
result_text = "Tension grows. This may lead to war."

