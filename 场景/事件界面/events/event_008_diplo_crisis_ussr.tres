[resource]
script = ExtResource("4_1gicc")
event_id = "diplomatic_crisis_ussr"
title = "Diplomatic crisis"
description = "Our relations with the USSR have reached a critically low level. Their propaganda already accuses China of all possible and impossible crimes, and our intelligence reports on the turmoil in the General Staff of the USSR and the movement of Soviet troops on the border. We urgently need to somehow correct the situation if we don't want the Third World War."
options = Array[ExtResource("2_8yby2")]([SubResource("Resource_uy464"), SubResource("Resource_172ff"), SubResource("Resource_45ccd"), SubResource("Resource_bq1dh")])
