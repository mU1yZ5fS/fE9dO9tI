[sub_resource type="Resource" id="Resource_5e2is"]
script = ExtResource("2_sir7f")
text = "Send in the PLA to restore order"
effects = Array[ExtResource("3_nsmhh")]([SubResource("Resource_jvjuj"), SubResource("Resource_q05h0"), SubResource("Resource_nxarn"), SubResource("Resource_8kypp")])
result_text = "The loyal parts of the PLA entered Xinjiang and quickly restored order. But the nationalists and the opposition will not forget this."

