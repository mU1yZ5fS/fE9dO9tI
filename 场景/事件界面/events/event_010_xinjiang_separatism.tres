[sub_resource type="Resource" id="Resource_b5j6h"]
script = ExtResource("2_sir7f")
text = "Organize a referendum"
disabled_text = "Need agents: 50 and money: 40"
enable_condition = SubResource("Resource_84tjk")
effects = Array[ExtResource("3_nsmhh")]([SubResource("Resource_6kyr3"), SubResource("Resource_4xhu0"), SubResource("Resource_sc6yf"), SubResource("Resource_kuiv2")])
result_text = "We organized a referendum in which the majority, of course, voted to preserve the status of Xinjiang. Dissatisfied nationalists and other radicals took to the streets, claiming falsification, but without past support these protests no longer pose a serious threat."

[resource]
script = ExtResource("5_6ax5d")
event_id = "xinjiang_separatism"
title = "Separatism in Xinjiang"
description = "Encouraged by liberals and nationalists, residents of the Xinjiang Uygur Autonomous Region took to mass demonstrations for independence and secession from the PRC, which gradually develop into unrest. People demand \"liberation\" from \"the occupation of 1949\" and the majority of ethnic Uighurs support them. However, there is a counterweight to them from the Hanzu, and some of the Uighurs are just satisfied with the requirements of greater autonomy than we can take advantage of."
options = Array[ExtResource("2_sir7f")]([SubResource("Resource_hojh7"), SubResource("Resource_7gmw0"), SubResource("Resource_5e2is"), SubResource("Resource_b5j6h")])
