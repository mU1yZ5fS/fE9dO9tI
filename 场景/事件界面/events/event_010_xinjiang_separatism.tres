key = "manpower"
value = -20.0

[sub_resource type="Resource" id="Resource_7gmw0"]
script = ExtResource("2_sir7f")
text = "Expand autonomy"
effects = Array[ExtResource("3_nsmhh")]([SubResource("Resource_5x2q2"), SubResource("Resource_wkqns")])
result_text = "We have further expanded the powers of local authorities and the rights of Xinjiang autonomy. It seems that the majority of the population is satisfied, but it gives the radicals more opportunities to promote separatism."

