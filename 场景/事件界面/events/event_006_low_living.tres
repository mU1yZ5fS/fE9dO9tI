[sub_resource type="Resource" id="Resource_ci02a"]
script = ExtResource("2_7q3cr")
text = "Call on business by carrot and stick policy to solve social problems"
disabled_text = "We can't call on business, we don't have it"
enable_condition = SubResource("Resource_t6mta")
effects = Array[ExtResource("3_jhbl4")]([SubResource("Resource_dxoeo"), SubResource("Resource_s0qw2")])
result_text = "Through the development of labor laws, government orders, benefits and banal coercion, we managed to force our businessmen to provide social support to the people, improve working conditions and housing conditions. However, they are not particularly happy to share their wealth with the people."

