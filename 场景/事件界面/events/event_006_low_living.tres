[sub_resource type="Resource" id="Resource_0rfux"]
script = ExtResource("2_7q3cr")
text = "Request foreign humanitarian assistance"
disabled_text = "We can't ask for help"
enable_condition = SubResource("Resource_jrvw5")
effects = Array[ExtResource("3_jhbl4")]([SubResource("Resource_p8dk3")])
result_text = "We requested foreign humanitarian assistance, which was provided. Volunteers from different countries and from the UN distribute food, as well as develop housing for people on free terms. However, such actions showed both our people and the world community that we cannot cope with such things on our own, which greatly undermines our prestige."

