[sub_resource type="Resource" id="Resource_24r3m"]
script = ExtResource("2_7q3cr")
text = "Arrange charity at the expense of the party and officials"
disabled_text = "Party does not want to share"
enable_condition = SubResource("Resource_u3u31")
effects = Array[ExtResource("3_jhbl4")]([SubResource("Resource_u5ik0"), SubResource("Resource_6lsck"), SubResource("Resource_vwsqe")])
result_text = "Speaking at the extraordinary party congress, you explained to the top the brunt of the situation and decided to allocate funds for social needs of the party and voluntarily-forcedly attracted party members and officials to participate in charity events. This, of course, raised the standard of living, but the party was not satisfied."

