[sub_resource type="Resource" id="Resource_k4ld1"]
script = ExtResource("2_26xx8")
text = "Disperse protest with the help of the army and police"
effects = Array[ExtResource("3_wtp08")]([SubResource("Resource_go142"), SubResource("Resource_2xqf4"), SubResource("Resource_dxjtg")])
result_text = "Following Jiang Qing and Zhang Chunqiao's line, we first used radio appeals to separate mourners from provocateurs, then moved in city police and the Peking Garrison to clear the square. Clashes and beatings occurred, but no one was killed."

[sub_resource type="Resource" id="Resource_qnvoa"]
script = ExtResource("3_wtp08")
key = "party_support"
value = 50.0

[sub_resource type="Resource" id="Resource_l3s7s"]
script = ExtResource("3_wtp08")
key = "people_support"
value = -50.0

[sub_resource type="Resource" id="Resource_uc8uy"]
script = ExtResource("2_26xx8")
text = "Call all to go away and disperse the remaining"
effects = Array[ExtResource("3_wtp08")]([SubResource("Resource_qnvoa"), SubResource("Resource_l3s7s")])
result_text = "At half past six in the evening, Wu De spoke over loudspeakers urging the crowd to disperse. Many left, some stayed. By night, city police cleared the remaining protest."

[sub_resource type="Resource" id="Resource_2wgik"]
script = ExtResource("3_wtp08")
key = "party_support"
value = -50.0

[sub_resource type="Resource" id="Resource_d4n3b"]
script = ExtResource("2_26xx8")
text = "Call everyone to go away and cordon off the rest until they leave"
effects = Array[ExtResource("3_wtp08")]([SubResource("Resource_2wgik")])
result_text = "Wu De spoke over loudspeakers urging the crowd to go home. Many left, but some stayed. By night, police cleared the square. No one was killed."

[sub_resource type="Resource" id="Resource_t6rfj"]
