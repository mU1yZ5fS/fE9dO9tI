[sub_resource type="Resource" id="Resource_34rdy"]
script = ExtResource("2_ej2j1")
text = "Request help from the USSR"
disabled_text = "We don't need handouts from revisionists!"
enable_condition = SubResource("Resource_7xqvo")
effects = Array[ExtResource("3_5caad")]([SubResource("Resource_ox7to"), SubResource("Resource_mg1ou"), SubResource("Resource_46v2u"), SubResource("Resource_ksm48")])
result_text = "The Soviet Union agreed how in the old days to help us with the modernization of industry. However, he doesn't particularly like distributing specialists and machines for nothing, and we've got some dependence on the USSR."

[sub_resource type="Resource" id="Resource_mpjt3"]
script = ExtResource("3_5caad")
