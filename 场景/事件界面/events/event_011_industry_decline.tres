[sub_resource type="Resource" id="Resource_k2ejb"]
script = ExtResource("2_ej2j1")
text = "Urgently allocate money for development"
effects = Array[ExtResource("3_5caad")]([SubResource("Resource_uuv4e"), SubResource("Resource_rp3s3")])
result_text = "Large funds from the budget were urgently allocated for the modernization of the industry, the purchase of imported technologies and the involvement of specialists in this area. The problem starts to be solved"

