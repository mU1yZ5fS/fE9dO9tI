[sub_resource type="Resource" id="Resource_5pjtm"]
script = ExtResource("2_1424i")
text = "严格执行运动，并在媒体上批判周恩来。"
disabled_text = "需要特定条件"
effects = Array[ExtResource("3_n54w4")]([SubResource("Resource_wao4a"), SubResource("Resource_oxui0"), SubResource("Resource_5mw0e"), SubResource("Resource_733gl"), SubResource("Resource_mtube"), SubResource("Resource_i0ifj"), SubResource("Resource_x0s11"), SubResource("Resource_rd4ue")])
result_text = "作为国务院总理兼公安部长，你亲自监督了运动的严格执行，并负责在报纸上发表对周恩来的批判。持续不断的宣传引起了民众对毛泽东和党内高层的广泛不满，尤其是对江青和继任者华国锋。"

[resource]
script = ExtResource("5_l7wvu")
event_id = "five_no"
title = "Five \"no\""
description = "恭喜你就任中华人民共和国国务院总理，华国锋同志。如你所知，你的前任周恩来因其清廉正直与行政才能，赢得了海内外人民的广泛尊敬。然而，他也是经济改革的积极推动者，并在党内提拔了改革派，例如他的门生邓小平。正因如此，1976年1月8日周恩来的逝世引起了民众的巨大悲痛，这也令毛泽东和中共领导层深感不满，他们对周的死反应极为冷淡。根据毛泽东的命令，发起了'五不准'运动——不准戴黑纱、不准送花圈、不准设灵堂、不准开追悼会、不准挂周恩来遗像——这到目前为止除了引发不满之外毫无作用。而你，作为新任总理，可以对这一运动的执行施加影响。"
options = Array[ExtResource("2_1424i")]([SubResource("Resource_3wupn"), SubResource("Resource_dmaco"), SubResource("Resource_5pjtm")])
