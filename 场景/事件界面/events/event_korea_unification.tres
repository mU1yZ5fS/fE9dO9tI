[sub_resource type="Resource" id="Resource_lj705"]
script = ExtResource("2_46nys")
text = "金平日 - 可控候选人"
disabled_text = "需要特工：250，资金：250"
enable_condition = SubResource("Resource_lmd16")
effects = Array[ExtResource("3_i1gde")]([SubResource("Resource_18kp7"), SubResource("Resource_f7lcp"), SubResource("Resource_n0ysg"), SubResource("Resource_0xxlt"), SubResource("Resource_1558c")])
result_text = "金平日是金正日的弟弟，年轻时曾是有名的浪荡子，因此失去了父亲的宠信。现在，在我们的影响下，我们可以把他推上统一朝鲜领导人的位置。"

