[sub_resource type="Resource" id="Resource_hj268"]
script = ExtResource("2_46nys")
text = "金正日 - 父亲的继承人"
effects = Array[ExtResource("3_i1gde")]([SubResource("Resource_fnhdc")])
result_text = "金正日长期以来一直被塑造为金日成的继承人。在他的父亲继续担任劳动党领袖的情况下，让他成为统一朝鲜的国家领导人，是局势的自然延续，也不太可能给朝鲜政治带来显著变化。"

