[resource]
script = ExtResource("5_v8hd3")
event_id = "diplomatic_crisis_usa"
title = "Diplomatic crisis"
description = "Our relations with the USA have reached a critically low level. Their propaganda already accuses China of all possible and impossible crimes, and our intelligence reports on the turmoil in the Pentagon and activity at American bases in Southeast Asia. We urgently need to somehow correct the situation if we don't want the Third World War."
options = Array[ExtResource("2_e30uj")]([SubResource("Resource_iqph1"), SubResource("Resource_43k7t"), SubResource("Resource_06ufc"), SubResource("Resource_0l65a"), SubResource("Resource_ld467")])
