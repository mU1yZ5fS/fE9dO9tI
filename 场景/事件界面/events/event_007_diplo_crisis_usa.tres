[sub_resource type="Resource" id="Resource_43k7t"]
script = ExtResource("2_e30uj")
text = "Pass a part of foreign policy positions as a sign of goodwill"
disabled_text = "Our influence is too weak, so we cannot limit it"
enable_condition = SubResource("Resource_fogln")
effects = Array[ExtResource("3_vn5nf")]([SubResource("Resource_hkxfe"), SubResource("Resource_gejl1"), SubResource("Resource_gfu06")])
result_text = "We have abandoned some foreign policy claims, reduced the support of loyal opposition in other countries and, in general, reduced the degree of interventionism of Chinese politics. This was positively perceived by the Ministry of Foreign Affairs of the USA, tensions decreased. Like our influence."

[sub_resource type="Resource" id="Resource_06ufc"]
script = ExtResource("2_e30uj")
text = "Launch nukes into imperialists!"
disabled_text = "Nobody wants a nuclear war"
result_text = "Tension grows. This leads to a nuclear confrontation."

